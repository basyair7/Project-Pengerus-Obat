#ifndef LCDDISPLAY_HPP
#define LCDDISPLAY_HPP

#include <Arduino.h>
#include <LiquidCrystal_I2C.h>

class LCDdisplay {
public:
    // LCDの初期化
    void init();
    // LCDのクリア
    void clear();
    // バックライトのオン/オフ
    void backlight(bool x);
    // 文字列の表示
    void print(const String& x, const uint8_t col, const uint8_t row);

public:
    int cols = 16, rows = 2;

private:
    LiquidCrystal_I2C* lcd = new LiquidCrystal_I2C(0x27, cols, rows);
};

#endif

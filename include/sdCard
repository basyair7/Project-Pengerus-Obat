#ifndef SDCARD_HPP
#define SDCARD_HPP

#include <Arduino.h>
#include <ArduinoJson.h>
#include <SD.h>
#include <SPI.h>
#include "TypeSerial"

// SDカードクラス
class SDCard {
public:
    void SDCardInit(); // SDカードの初期化

public:
    // 設定を追加する
    void addConfig(const String& configName, int id, int minute, int speed);
    // 設定を読み取る
    void readConfig(const String& configName, int* id, int* minute, int* speed);
    void removeConfig(const String& configName); // 設定を削除する
    // レポートを書き込む
    void writeReport(String date, String time, String finishTime, String speed, int _speed_pwm);

private:
    // 設定を初期化する
    void initializeConfig();

private:
    String _read(String cfile); // ファイルからデータを読み取る
    void _write(String cfile, String valJson); // ファイルにデータを書き込む
    bool _remove(String cfile); // ファイルを削除する
    
private:
    File file;
    const char* fileConfig  = "config.json";
    const char* fileReport = "report.txt";
};

#endif
